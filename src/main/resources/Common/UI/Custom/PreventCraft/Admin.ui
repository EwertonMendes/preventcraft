$Common = "../Common.ui";

$Common.@PageOverlay {
  LayoutMode: CenterMiddle;

  $Common.@DecoratedContainer {
    Anchor: (Width: 1120, Height: 850);

    #Title {
      Label #AdminTitle {
        Style: (...$Common.@DefaultLabelStyle, FontSize: 18, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center, TextColor: #F4D06F);
        Padding: (Horizontal: 19);
        Text: "PreventCraft Administration";
      }
    }

    #Content {
      LayoutMode: Top;
      Padding: (Top: 14, Bottom: 14, Left: 20, Right: 20);

      Group #StatusGroup {
        Anchor: (Height: 46, Bottom: 8);
        LayoutMode: Full;
        Visible: false;
        Label #StatusLabel { Anchor: (Full: 0); Style: (...$Common.@DefaultLabelStyle, Wrap: true, VerticalAlignment: Center, TextColor: #96d4ff); Text: ""; }
      }

      Group #MetricsRow {
        Anchor: (Height: 54, Bottom: 10);
        LayoutMode: Left;
        Label #ModeLabel { Style: (...$Common.@DefaultLabelStyle, VerticalAlignment: Center, TextColor: #DDE7F3); Anchor: (Width: 260, Height: 44, Right: 10); Text: "Mode"; }
        Label #RulesCountLabel { Style: (...$Common.@DefaultLabelStyle, VerticalAlignment: Center, TextColor: #DDE7F3); Anchor: (Width: 220, Height: 44, Right: 10); Text: "Rules"; }
        Label #LuckPermsLabel { Style: (...$Common.@DefaultLabelStyle, VerticalAlignment: Center, TextColor: #DDE7F3); Anchor: (Width: 240, Height: 44, Right: 10); Text: "LuckPerms"; }
        Label #CatalogLabel { Style: (...$Common.@DefaultLabelStyle, VerticalAlignment: Center, TextColor: #DDE7F3); FlexWeight: 1; Anchor: (Height: 44); Text: "Catalog"; }
      }

      Group #SearchRow {
        Anchor: (Height: 48, Bottom: 8);
        LayoutMode: Left;
        Label #SearchLabel { Style: (...$Common.@DefaultLabelStyle, VerticalAlignment: Center); Anchor: (Width: 110, Height: 38, Right: 10); Text: "Search"; }
        $Common.@TextField #SearchField { Anchor: (Height: 38, Right: 8); FlexWeight: 1; PlaceholderText: "Item, bench, group, player or rule id"; MaxLength: 256; }
        $Common.@SecondaryTextButton #SearchButton { @Text = "Search"; Anchor: (Width: 120, Height: 42, Right: 8); }
        $Common.@TertiaryTextButton #ClearSearchButton { @Text = "Clear"; Anchor: (Width: 110, Height: 42); }
      }

      Group #ActionsRow1 {
        Anchor: (Height: 48, Bottom: 6);
        LayoutMode: Left;
        $Common.@TextButton #AddItemRuleButton { @Text = "Block item craft"; Anchor: (Width: 190, Height: 42, Right: 8); }
        $Common.@TextButton #AddBenchCraftRuleButton { @Text = "Block bench craft"; Anchor: (Width: 200, Height: 42, Right: 8); }
        $Common.@TextButton #AddBenchAccessRuleButton { @Text = "Block bench access"; Anchor: (Width: 210, Height: 42, Right: 8); }
        $Common.@SecondaryTextButton #ReloadButton { @Text = "Reload JSON"; Anchor: (Width: 160, Height: 42, Right: 8); }
        $Common.@SecondaryTextButton #BackupButton { @Text = "Backup"; Anchor: (Width: 130, Height: 42); }
      }

      Group #ActionsRow2 {
        Anchor: (Height: 44, Bottom: 8);
        LayoutMode: Left;
        Label #ImportHintLabel { Style: (...$Common.@DefaultLabelStyle, VerticalAlignment: Center, TextColor: #9fb1c6); FlexWeight: 1; Anchor: (Height: 38, Right: 10); Text: "CraftRestrict import reads LuckPerms nodes and creates JSON rules."; }
        $Common.@SecondaryTextButton #ImportDryRunButton { @Text = "Dry run import"; Anchor: (Width: 180, Height: 40, Right: 8); }
        $Common.@TextButton #ImportApplyButton { @Text = "Apply import"; Anchor: (Width: 160, Height: 40); }
      }

      Group #RulesScroll {
        FlexWeight: 1;
        LayoutMode: TopScrolling;
        ScrollbarStyle: $Common.@DefaultScrollbarStyle;
        KeepScrollPosition: true;
        Padding: (Right: 10);

        Label #RulesLabel { Style: (...$Common.@DefaultLabelStyle, RenderBold: true); Anchor: (Height: 24, Bottom: 8); Text: "Rules"; }

          Group #RuleRow0 {
            Anchor: (Height: 106, Bottom: 8);
            LayoutMode: Left;
            Padding: (Top: 8, Bottom: 8, Left: 12, Right: 12);
            Background: #1d3044(0.78);
            OutlineColor: #45617d(0.85);
            OutlineSize: 1;

            Group #RuleIconPanel0 {
              Anchor: (Width: 64, Height: 64, Top: 13, Right: 12);
              LayoutMode: Center;
              Background: #142437(0.92);
              OutlineColor: #55728f(0.72);
              OutlineSize: 1;
              ItemIcon #RuleIcon0 { Anchor: (Width: 52, Height: 50); ItemId: "Ingredient_Stick"; ShowItemTooltip: false; HitTestVisible: false; Visible: false; }
              Label #RuleKindIcon0 { Style: (...$Common.@DefaultLabelStyle, FontSize: 10, Wrap: true, HorizontalAlignment: Center, VerticalAlignment: Center, TextColor: #e9d27e); Anchor: (Width: 58, Height: 48); Text: "RULE"; }
            }

            Group #RuleText0 {
              FlexWeight: 1;
              Anchor: (Height: 86, Right: 12);
              LayoutMode: Top;
              Label #RuleName0 { Style: (...$Common.@DefaultLabelStyle, RenderBold: true); Anchor: (Height: 24); Text: "Rule"; }
              Label #RuleDescription0 { Style: (...$Common.@DefaultLabelStyle, Wrap: true, FontSize: 11, TextColor: #a8bbcf); Anchor: (Height: 62); Text: "Rule details"; }
            }

            Group #RuleActions0 {
              Anchor: (Width: 290, Height: 44, Top: 23);
              LayoutMode: Left;
              $Common.@SecondaryTextButton #EditButton0 { @Text = "Edit"; Anchor: (Width: 112, Height: 42, Right: 10); }
              $Common.@CancelTextButton #DeleteButton0 { @Text = "Delete"; Anchor: (Width: 168, Height: 42); }
            }

            Group #DeleteConfirmation0 {
              Anchor: (Width: 650, Height: 54, Top: 18);
              LayoutMode: Left;
              Visible: false;
              Label #DeleteConfirmationLabel0 { Style: (...$Common.@DefaultLabelStyle, Wrap: true, VerticalAlignment: Center, TextColor: #e9b65f); FlexWeight: 1; Anchor: (Height: 50, Right: 10); Text: "Delete?"; }
              $Common.@SecondaryTextButton #CancelDeleteButton0 { @Text = "Cancel"; Anchor: (Width: 120, Height: 42, Right: 10); }
              $Common.@CancelTextButton #ConfirmDeleteButton0 { @Text = "Confirm"; Anchor: (Width: 160, Height: 42); }
            }
          }

