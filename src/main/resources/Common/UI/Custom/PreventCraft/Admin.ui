$Common = "../Common.ui";

$Common.@PageOverlay {
  LayoutMode: CenterMiddle;

  $Common.@DecoratedContainer {
    Anchor: (Width: 1120, Height: 850);

    #Title {
      Label #AdminTitle {
        Style: (...$Common.@DefaultLabelStyle, FontSize: 18, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center, TextColor: #F4D06F);
        Padding: (Horizontal: 19);
        Text: "PreventCraft";
      }
    }

    #Content {
      LayoutMode: Top;
      Padding: (Top: 14, Bottom: 14, Left: 20, Right: 20);

      Group #StatusBar {
        Anchor: (Height: 68, Bottom: 10);
        LayoutMode: Full;
        Padding: (Top: 10, Bottom: 10, Left: 14, Right: 14);
        Background: #15263a(0.70);
        OutlineColor: #45617d(0.65);
        OutlineSize: 1;
        Label #StatusLabel {
          Anchor: (Full: 0);
          Style: (...$Common.@DefaultLabelStyle, Wrap: true, VerticalAlignment: Center, TextColor: #96d4ff);
          Text: "";
        }
      }

      Group #MetricsRow {
        Anchor: (Height: 98, Bottom: 10);
        LayoutMode: Left;
        Group #MetricCard0 {
          Anchor: (Width: 262, Height: 92, Right: 10);
          LayoutMode: Top;
          Padding: (Top: 12, Bottom: 10, Left: 14, Right: 14);
          Background: #1d3044(0.80);
          OutlineColor: #45617d(0.85);
          OutlineSize: 1;
          Label #ModeCardTitle { Style: (...$Common.@DefaultLabelStyle, FontSize: 10, RenderBold: true, TextColor: #8fa5bb); Anchor: (Height: 18); Text: "Metric"; }
          Label #ModeCardValue { Style: (...$Common.@DefaultLabelStyle, FontSize: 18, RenderBold: true, TextColor: #dde7f3); Anchor: (Height: 30); Text: "Value"; }
          Label #ModeCardSub { Style: (...$Common.@DefaultLabelStyle, FontSize: 10, Wrap: true, TextColor: #96a9be); FlexWeight: 1; Anchor: (Height: 24); Text: ""; }
        }
        Group #MetricCard1 {
          Anchor: (Width: 262, Height: 92, Right: 10);
          LayoutMode: Top;
          Padding: (Top: 12, Bottom: 10, Left: 14, Right: 14);
          Background: #1d3044(0.80);
          OutlineColor: #45617d(0.85);
          OutlineSize: 1;
          Label #RulesCardTitle { Style: (...$Common.@DefaultLabelStyle, FontSize: 10, RenderBold: true, TextColor: #8fa5bb); Anchor: (Height: 18); Text: "Metric"; }
          Label #RulesCardValue { Style: (...$Common.@DefaultLabelStyle, FontSize: 18, RenderBold: true, TextColor: #dde7f3); Anchor: (Height: 30); Text: "Value"; }
          Label #RulesCardSub { Style: (...$Common.@DefaultLabelStyle, FontSize: 10, Wrap: true, TextColor: #96a9be); FlexWeight: 1; Anchor: (Height: 24); Text: ""; }
        }
        Group #MetricCard2 {
          Anchor: (Width: 262, Height: 92, Right: 10);
          LayoutMode: Top;
          Padding: (Top: 12, Bottom: 10, Left: 14, Right: 14);
          Background: #1d3044(0.80);
          OutlineColor: #45617d(0.85);
          OutlineSize: 1;
          Label #LuckPermsCardTitle { Style: (...$Common.@DefaultLabelStyle, FontSize: 10, RenderBold: true, TextColor: #8fa5bb); Anchor: (Height: 18); Text: "Metric"; }
          Label #LuckPermsCardValue { Style: (...$Common.@DefaultLabelStyle, FontSize: 18, RenderBold: true, TextColor: #dde7f3); Anchor: (Height: 30); Text: "Value"; }
          Label #LuckPermsCardSub { Style: (...$Common.@DefaultLabelStyle, FontSize: 10, Wrap: true, TextColor: #96a9be); FlexWeight: 1; Anchor: (Height: 24); Text: ""; }
        }
        Group #MetricCard3 {
          Anchor: (Width: 262, Height: 92);
          LayoutMode: Top;
          Padding: (Top: 12, Bottom: 10, Left: 14, Right: 14);
          Background: #1d3044(0.80);
          OutlineColor: #45617d(0.85);
          OutlineSize: 1;
          Label #CatalogCardTitle { Style: (...$Common.@DefaultLabelStyle, FontSize: 10, RenderBold: true, TextColor: #8fa5bb); Anchor: (Height: 18); Text: "Metric"; }
          Label #CatalogCardValue { Style: (...$Common.@DefaultLabelStyle, FontSize: 18, RenderBold: true, TextColor: #dde7f3); Anchor: (Height: 30); Text: "Value"; }
          Label #CatalogCardSub { Style: (...$Common.@DefaultLabelStyle, FontSize: 10, Wrap: true, TextColor: #96a9be); FlexWeight: 1; Anchor: (Height: 24); Text: ""; }
        }
      }

      Group #SearchRow {
        Anchor: (Height: 46, Bottom: 8);
        LayoutMode: Left;
        $Common.@TextField #SearchField { Anchor: (Height: 38, Right: 8); FlexWeight: 1; PlaceholderText: "Item, bancada, grupo, jogador ou ID da regra"; MaxLength: 256; }
        $Common.@SecondaryTextButton #SearchButton { @Text = "Buscar"; Anchor: (Width: 132, Height: 42, Right: 8); }
        $Common.@TertiaryTextButton #ClearSearchButton { @Text = "Limpar"; Anchor: (Width: 116, Height: 42); }
      }

      Group #ActionsRow1 {
        Anchor: (Height: 48, Bottom: 8);
        LayoutMode: Left;
        $Common.@TextButton #AddItemRuleButton { @Text = "Bloquear craft de item"; Anchor: (Width: 342, Height: 42, Right: 8); }
        $Common.@TextButton #AddBenchCraftRuleButton { @Text = "Bloquear craft de bancada"; Anchor: (Width: 342, Height: 42, Right: 8); }
        $Common.@TextButton #AddBenchAccessRuleButton { @Text = "Bloquear acesso à bancada"; Anchor: (Width: 342, Height: 42); }
      }

      Group #ActionsRow2 {
        Anchor: (Height: 48, Bottom: 10);
        LayoutMode: Left;
        $Common.@SecondaryTextButton #ReloadButton { @Text = "Recarregar JSON"; Anchor: (Width: 180, Height: 42, Right: 8); }
        $Common.@SecondaryTextButton #BackupButton { @Text = "Backup"; Anchor: (Width: 140, Height: 42, Right: 20); }
        $Common.@SecondaryTextButton #ImportDryRunButton { @Text = "Simular importação"; Anchor: (Width: 220, Height: 42, Right: 8); }
        $Common.@TextButton #ImportApplyButton { @Text = "Aplicar importação"; Anchor: (Width: 200, Height: 42); }
      }

      Group #RulesScroll {
        FlexWeight: 1;
        LayoutMode: TopScrolling;
        ScrollbarStyle: $Common.@DefaultScrollbarStyle;
        KeepScrollPosition: true;
        Padding: (Right: 10);

        Label #RulesLabel { Style: (...$Common.@DefaultLabelStyle, RenderBold: true); Anchor: (Height: 24, Bottom: 8); Text: "Regras"; }

        Group #RuleRow0 {
          Anchor: (Height: 108, Bottom: 8);
          LayoutMode: Left;
          Padding: (Top: 8, Bottom: 8, Left: 12, Right: 12);
          Background: #1d3044(0.78);
          OutlineColor: #45617d(0.85);
          OutlineSize: 1;

          Group #RuleIconPanel0 {
            Anchor: (Width: 66, Height: 66, Top: 13, Right: 12);
            LayoutMode: Center;
            Background: #142437(0.92);
            OutlineColor: #55728f(0.72);
            OutlineSize: 1;
            ItemIcon #RuleIcon0 { Anchor: (Width: 54, Height: 52); ItemId: "Ingredient_Stick"; ShowItemTooltip: false; HitTestVisible: false; Visible: false; }
            Label #RuleKindIcon0 { Style: (...$Common.@DefaultLabelStyle, FontSize: 10, Wrap: true, HorizontalAlignment: Center, VerticalAlignment: Center, TextColor: #e9d27e); Anchor: (Width: 60, Height: 48); Text: "RULE"; }
          }

          Group #RuleText0 {
            FlexWeight: 1;
            Anchor: (Height: 88, Right: 12);
            LayoutMode: Top;
            Label #RuleName0 { Style: (...$Common.@DefaultLabelStyle, RenderBold: true); Anchor: (Height: 24); Text: "Rule"; }
            Label #RuleDescription0 { Style: (...$Common.@DefaultLabelStyle, Wrap: true, FontSize: 11, TextColor: #a8bbcf); Anchor: (Height: 62); Text: "Rule details"; }
          }

          Group #RuleActions0 {
            Anchor: (Width: 290, Height: 44, Top: 24);
            LayoutMode: Left;
            $Common.@SecondaryTextButton #EditButton0 { @Text = "Edit"; Anchor: (Width: 112, Height: 42, Right: 10); }
            $Common.@CancelTextButton #DeleteButton0 { @Text = "Delete"; Anchor: (Width: 168, Height: 42); }
          }

          Group #DeleteConfirmation0 {
            Anchor: (Width: 650, Height: 54, Top: 18);
            LayoutMode: Left;
            Visible: false;
            Label #DeleteConfirmationLabel0 { Style: (...$Common.@DefaultLabelStyle, Wrap: true, VerticalAlignment: Center, TextColor: #e9b65f); FlexWeight: 1; Anchor: (Height: 50, Right: 10); Text: "Delete?"; }
            $Common.@SecondaryTextButton #CancelDeleteButton0 { @Text = "Cancel"; Anchor: (Width: 120, Height: 42, Right: 10); }
            $Common.@CancelTextButton #ConfirmDeleteButton0 { @Text = "Confirm"; Anchor: (Width: 160, Height: 42); }
          }
        }
        Group #RuleRow1 {
