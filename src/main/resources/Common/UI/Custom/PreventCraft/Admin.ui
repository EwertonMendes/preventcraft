$Common = "../Common.ui";

$Common.@PageOverlay {
  LayoutMode: CenterMiddle;

  $Common.@DecoratedContainer {
    Anchor: (Width: 1120, Height: 850);

    #Title {
      Label #AdminTitle {
        Style: (...$Common.@DefaultLabelStyle, FontSize: 18, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center, TextColor: #F4D06F);
        Padding: (Horizontal: 19);
        Text: "PreventCraft";
      }
    }

    #Content {
      LayoutMode: Top;
      Padding: (Top: 14, Bottom: 14, Left: 20, Right: 20);

      Group #TabBar {
        Anchor: (Height: 48, Bottom: 10);
        LayoutMode: Left;
        $Common.@TextButton #RulesTabActive { @Text = "Regras"; Anchor: (Width: 220, Height: 42, Right: 8); }
        $Common.@SecondaryTextButton #RulesTabInactive { @Text = "Regras"; Anchor: (Width: 220, Height: 42, Right: 8); Visible: false; }
        $Common.@TextButton #MaintenanceTabActive { @Text = "Manutenção"; Anchor: (Width: 220, Height: 42); Visible: false; }
        $Common.@SecondaryTextButton #MaintenanceTabInactive { @Text = "Manutenção"; Anchor: (Width: 220, Height: 42); }
        Group { FlexWeight: 1; }
      }

      Group #RulesFeedback {
        Anchor: (Height: 46, Bottom: 10);
        LayoutMode: Left;
        Padding: (Top: 8, Bottom: 8, Left: 12, Right: 12);
        Background: #17344a(0.78);
        OutlineColor: #4d82a6(0.78);
        OutlineSize: 1;
        Visible: false;
        Label { Style: (...$Common.@DefaultLabelStyle, FontSize: 16, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center, TextColor: #8fd3ff); Anchor: (Width: 30, Height: 28, Right: 8); Text: "i"; }
        Label #StatusLabel { Style: (...$Common.@DefaultLabelStyle, Wrap: true, VerticalAlignment: Center, TextColor: #b9dcf5); FlexWeight: 1; Anchor: (Height: 28); Text: ""; }
      }

      Group #MaintenanceView {
        FlexWeight: 1;
        LayoutMode: Top;
        Visible: false;

        Group #MaintenanceHero {
          Anchor: (Height: 76, Bottom: 12);
          LayoutMode: Top;
          Padding: (Top: 10, Bottom: 8, Left: 14, Right: 14);
          Background: #162a3d(0.78);
          OutlineColor: #45617d(0.72);
          OutlineSize: 1;
          Label #MaintenanceTitle { Style: (...$Common.@DefaultLabelStyle, FontSize: 18, RenderBold: true, TextColor: #f1cf78); Anchor: (Height: 27); Text: "Manutenção e migração"; }
          Label #MaintenanceSubtitle { Style: (...$Common.@DefaultLabelStyle, FontSize: 12, Wrap: true, TextColor: #9eb2c7); FlexWeight: 1; Anchor: (Height: 26); Text: "Ferramentas ocasionais para administrar os arquivos e importar regras."; }
        }

        Group #MaintenanceCards {
          Anchor: (Height: 208, Bottom: 12);
          LayoutMode: Left;

          Group #ConfigToolsCard {
            FlexWeight: 1;
            Anchor: (Height: 208, Right: 10);
            LayoutMode: Top;
            Padding: (Top: 14, Bottom: 14, Left: 16, Right: 16);
            Background: #1d3044(0.82);
            OutlineColor: #45617d(0.82);
            OutlineSize: 1;
            Label #ConfigToolsTitle { Style: (...$Common.@DefaultLabelStyle, FontSize: 16, RenderBold: true, TextColor: #dde7f3); Anchor: (Height: 28); Text: "Arquivo de configuração"; }
            Label #ConfigToolsDescription { Style: (...$Common.@DefaultLabelStyle, FontSize: 12, Wrap: true, TextColor: #96a9be); FlexWeight: 1; Anchor: (Height: 78); Text: "Recarregue o JSON depois de uma edição externa ou crie uma cópia de segurança antes de grandes mudanças."; }
            Group { Anchor: (Height: 44); LayoutMode: Left;
              $Common.@SecondaryTextButton #ReloadButton { @Text = "Recarregar JSON"; FlexWeight: 1; Anchor: (Height: 42, Right: 8); }
              $Common.@SecondaryTextButton #BackupButton { @Text = "Criar backup"; FlexWeight: 1; Anchor: (Height: 42); }
            }
          }

          Group #ImportToolsCard {
            FlexWeight: 1;
            Anchor: (Height: 208);
            LayoutMode: Top;
            Padding: (Top: 14, Bottom: 14, Left: 16, Right: 16);
            Background: #1d3044(0.82);
            OutlineColor: #45617d(0.82);
            OutlineSize: 1;
            Label #ImportToolsTitle { Style: (...$Common.@DefaultLabelStyle, FontSize: 16, RenderBold: true, TextColor: #dde7f3); Anchor: (Height: 28); Text: "Importar do CraftRestrict"; }
            Label #ImportToolsDescription { Style: (...$Common.@DefaultLabelStyle, FontSize: 12, Wrap: true, TextColor: #96a9be); FlexWeight: 1; Anchor: (Height: 78); Text: "Analise as permissões do LuckPerms e converta regras compatíveis para o PreventCraft."; }
            Group #ImportActions { Anchor: (Height: 44); LayoutMode: Left;
              $Common.@SecondaryTextButton #ImportDryRunButton { @Text = "Simular primeiro"; FlexWeight: 1; Anchor: (Height: 42, Right: 8); }
              $Common.@TextButton #ImportApplyButton { @Text = "Aplicar importação"; FlexWeight: 1; Anchor: (Height: 42); }
            }
            Group #ImportConfirmation { Anchor: (Height: 48); LayoutMode: Left; Visible: false;
              Label #ImportConfirmationLabel { Style: (...$Common.@DefaultLabelStyle, FontSize: 11, Wrap: true, VerticalAlignment: Center, TextColor: #e9c46a); FlexWeight: 1; Anchor: (Height: 46, Right: 8); Text: "Aplicar agora?"; }
              $Common.@SecondaryTextButton #CancelImportButton { @Text = "Cancelar"; Anchor: (Width: 105, Height: 40, Right: 8); }
              $Common.@TextButton #ConfirmImportButton { @Text = "Confirmar"; Anchor: (Width: 120, Height: 40); }
            }
          }
        }

        Group #MaintenanceFeedback {
          FlexWeight: 1;
          LayoutMode: Top;
          Padding: (Top: 14, Bottom: 14, Left: 16, Right: 16);
          Background: #142437(0.84);
          OutlineColor: #45617d(0.76);
          OutlineSize: 1;

          Group #FeedbackHeader { Anchor: (Height: 42, Bottom: 8); LayoutMode: Left;
            Group #FeedbackIdleIcon { Anchor: (Width: 38, Height: 38, Right: 10); LayoutMode: Center; Background: #26374a; OutlineColor: #68829c; OutlineSize: 1;
              Label { Style: (...$Common.@DefaultLabelStyle, FontSize: 18, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center, TextColor: #a8bbcf); Anchor: (Width: 32, Height: 32); Text: "i"; }
            }
            Group #FeedbackSuccessIcon { Anchor: (Width: 38, Height: 38, Right: 10); LayoutMode: Center; Background: #173c32; OutlineColor: #49a884; OutlineSize: 1; Visible: false;
              Label { Style: (...$Common.@DefaultLabelStyle, FontSize: 11, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center, TextColor: #7de0b7); Anchor: (Width: 32, Height: 32); Text: "OK"; }
            }
            Group #FeedbackErrorIcon { Anchor: (Width: 38, Height: 38, Right: 10); LayoutMode: Center; Background: #452530; OutlineColor: #c65d72; OutlineSize: 1; Visible: false;
              Label { Style: (...$Common.@DefaultLabelStyle, FontSize: 18, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center, TextColor: #ff8ca1); Anchor: (Width: 32, Height: 32); Text: "!"; }
            }
            Group { FlexWeight: 1; Anchor: (Height: 40); LayoutMode: Top;
              Label #FeedbackTitle { Style: (...$Common.@DefaultLabelStyle, FontSize: 16, RenderBold: true, TextColor: #dde7f3); Anchor: (Height: 22); Text: "Tudo pronto"; }
              Label #FeedbackCaption { Style: (...$Common.@DefaultLabelStyle, FontSize: 10, TextColor: #8398ad); Anchor: (Height: 16); Text: "Resultado da última operação"; }
            }
          }

          Label #MaintenanceFeedbackMessage { Style: (...$Common.@DefaultLabelStyle, FontSize: 12, Wrap: true, TextColor: #a8bbcf); Anchor: (Height: 48, Bottom: 10); Text: "Escolha uma ferramenta acima. O resultado aparecerá aqui de forma resumida."; }

          Group #ImportSummary { Anchor: (Height: 154); LayoutMode: Top; Visible: false;
            Group #ImportStats { Anchor: (Height: 68, Bottom: 8); LayoutMode: Left;
              Group { FlexWeight: 1; Anchor: (Height: 66, Right: 8); LayoutMode: Top; Padding: (Top: 8, Left: 10, Right: 10); Background: #1d3044(0.78); Label #ImportHoldersValue { Style: (...$Common.@DefaultLabelStyle, FontSize: 17, RenderBold: true); Anchor: (Height: 25); Text: "0"; } Label #ImportHoldersLabel { Style: (...$Common.@DefaultLabelStyle, FontSize: 9, TextColor: #8398ad); Anchor: (Height: 18); Text: "Titulares"; } }
              Group { FlexWeight: 1; Anchor: (Height: 66, Right: 8); LayoutMode: Top; Padding: (Top: 8, Left: 10, Right: 10); Background: #1d3044(0.78); Label #ImportNodesValue { Style: (...$Common.@DefaultLabelStyle, FontSize: 17, RenderBold: true); Anchor: (Height: 25); Text: "0"; } Label #ImportNodesLabel { Style: (...$Common.@DefaultLabelStyle, FontSize: 9, TextColor: #8398ad); Anchor: (Height: 18); Text: "Permissões"; } }
              Group { FlexWeight: 1; Anchor: (Height: 66, Right: 8); LayoutMode: Top; Padding: (Top: 8, Left: 10, Right: 10); Background: #173c32(0.78); Label #ImportRulesValue { Style: (...$Common.@DefaultLabelStyle, FontSize: 17, RenderBold: true, TextColor: #7de0b7); Anchor: (Height: 25); Text: "0"; } Label #ImportRulesLabel { Style: (...$Common.@DefaultLabelStyle, FontSize: 9, TextColor: #73b99d); Anchor: (Height: 18); Text: "Regras novas"; } }
              Group { FlexWeight: 1; Anchor: (Height: 66, Right: 8); LayoutMode: Top; Padding: (Top: 8, Left: 10, Right: 10); Background: #1d3044(0.78); Label #ImportDuplicatesValue { Style: (...$Common.@DefaultLabelStyle, FontSize: 17, RenderBold: true); Anchor: (Height: 25); Text: "0"; } Label #ImportDuplicatesLabel { Style: (...$Common.@DefaultLabelStyle, FontSize: 9, TextColor: #8398ad); Anchor: (Height: 18); Text: "Duplicadas"; } }
              Group { FlexWeight: 1; Anchor: (Height: 66, Right: 8); LayoutMode: Top; Padding: (Top: 8, Left: 10, Right: 10); Background: #1d3044(0.78); Label #ImportWildcardsValue { Style: (...$Common.@DefaultLabelStyle, FontSize: 17, RenderBold: true); Anchor: (Height: 25); Text: "0"; } Label #ImportWildcardsLabel { Style: (...$Common.@DefaultLabelStyle, FontSize: 9, TextColor: #8398ad); Anchor: (Height: 18); Text: "Wildcards"; } }
              Group { FlexWeight: 1; Anchor: (Height: 66); LayoutMode: Top; Padding: (Top: 8, Left: 10, Right: 10); Background: #1d3044(0.78); Label #ImportUnknownValue { Style: (...$Common.@DefaultLabelStyle, FontSize: 17, RenderBold: true); Anchor: (Height: 25); Text: "0"; } Label #ImportUnknownLabel { Style: (...$Common.@DefaultLabelStyle, FontSize: 9, TextColor: #8398ad); Anchor: (Height: 18); Text: "Ignoradas"; } }
            }
            Label #ImportResolutionLabel { Style: (...$Common.@DefaultLabelStyle, FontSize: 10, Wrap: true, TextColor: #e9c46a); Anchor: (Height: 40); Text: "IDs encontrados no catálogo."; }
            Label #ImportReportLabel { Style: (...$Common.@DefaultLabelStyle, FontSize: 10, TextColor: #8fd3ff); Anchor: (Height: 28); Text: "Relatório: -"; }
          }
        }
      }

      Group #MetricsRow {
        Anchor: (Height: 98, Bottom: 10);
        LayoutMode: Left;
        Group #MetricCard0 {
          Anchor: (Width: 262, Height: 92, Right: 10);
          LayoutMode: Top;
          Padding: (Top: 12, Bottom: 10, Left: 14, Right: 14);
          Background: #1d3044(0.80);
          OutlineColor: #45617d(0.85);
          OutlineSize: 1;
          Label #ModeCardTitle { Style: (...$Common.@DefaultLabelStyle, FontSize: 10, RenderBold: true, TextColor: #8fa5bb); Anchor: (Height: 18); Text: "Metric"; }
          Label #ModeCardValue { Style: (...$Common.@DefaultLabelStyle, FontSize: 18, RenderBold: true, TextColor: #dde7f3); Anchor: (Height: 30); Text: "Value"; }
          Label #ModeCardSub { Style: (...$Common.@DefaultLabelStyle, FontSize: 10, Wrap: true, TextColor: #96a9be); FlexWeight: 1; Anchor: (Height: 24); Text: ""; }
        }
        Group #MetricCard1 {
          Anchor: (Width: 262, Height: 92, Right: 10);
          LayoutMode: Top;
          Padding: (Top: 12, Bottom: 10, Left: 14, Right: 14);
          Background: #1d3044(0.80);
          OutlineColor: #45617d(0.85);
          OutlineSize: 1;
          Label #RulesCardTitle { Style: (...$Common.@DefaultLabelStyle, FontSize: 10, RenderBold: true, TextColor: #8fa5bb); Anchor: (Height: 18); Text: "Metric"; }
          Label #RulesCardValue { Style: (...$Common.@DefaultLabelStyle, FontSize: 18, RenderBold: true, TextColor: #dde7f3); Anchor: (Height: 30); Text: "Value"; }
          Label #RulesCardSub { Style: (...$Common.@DefaultLabelStyle, FontSize: 10, Wrap: true, TextColor: #96a9be); FlexWeight: 1; Anchor: (Height: 24); Text: ""; }
        }
        Group #MetricCard2 {
          Anchor: (Width: 262, Height: 92, Right: 10);
          LayoutMode: Top;
          Padding: (Top: 12, Bottom: 10, Left: 14, Right: 14);
          Background: #1d3044(0.80);
          OutlineColor: #45617d(0.85);
          OutlineSize: 1;
          Label #LuckPermsCardTitle { Style: (...$Common.@DefaultLabelStyle, FontSize: 10, RenderBold: true, TextColor: #8fa5bb); Anchor: (Height: 18); Text: "Metric"; }
          Label #LuckPermsCardValue { Style: (...$Common.@DefaultLabelStyle, FontSize: 18, RenderBold: true, TextColor: #dde7f3); Anchor: (Height: 30); Text: "Value"; }
          Label #LuckPermsCardSub { Style: (...$Common.@DefaultLabelStyle, FontSize: 10, Wrap: true, TextColor: #96a9be); FlexWeight: 1; Anchor: (Height: 24); Text: ""; }
        }
        Group #MetricCard3 {
          Anchor: (Width: 262, Height: 92);
          LayoutMode: Top;
          Padding: (Top: 12, Bottom: 10, Left: 14, Right: 14);
          Background: #1d3044(0.80);
          OutlineColor: #45617d(0.85);
          OutlineSize: 1;
          Label #CatalogCardTitle { Style: (...$Common.@DefaultLabelStyle, FontSize: 10, RenderBold: true, TextColor: #8fa5bb); Anchor: (Height: 18); Text: "Metric"; }
          Label #CatalogCardValue { Style: (...$Common.@DefaultLabelStyle, FontSize: 18, RenderBold: true, TextColor: #dde7f3); Anchor: (Height: 30); Text: "Value"; }
          Label #CatalogCardSub { Style: (...$Common.@DefaultLabelStyle, FontSize: 10, Wrap: true, TextColor: #96a9be); FlexWeight: 1; Anchor: (Height: 24); Text: ""; }
        }
      }

      Group #SearchRow {
        Anchor: (Height: 46, Bottom: 8);
        LayoutMode: Left;
        $Common.@TextField #SearchField { Anchor: (Height: 38, Right: 8); FlexWeight: 1; PlaceholderText: "Item, bancada, grupo, jogador ou ID da regra"; MaxLength: 256; }
        $Common.@SecondaryTextButton #SearchButton { @Text = "Buscar"; Anchor: (Width: 132, Height: 42, Right: 8); }
        $Common.@TertiaryTextButton #ClearSearchButton { @Text = "Limpar"; Anchor: (Width: 116, Height: 42); }
      }

      Group #ActionsRow1 {
        Anchor: (Height: 48, Bottom: 8);
        LayoutMode: Left;
        $Common.@TextButton #AddItemRuleButton { @Text = "Bloquear craft de item"; Anchor: (Width: 342, Height: 42, Right: 8); }
        $Common.@TextButton #AddBenchCraftRuleButton { @Text = "Bloquear craft de bancada"; Anchor: (Width: 342, Height: 42, Right: 8); }
        $Common.@TextButton #AddBenchAccessRuleButton { @Text = "Bloquear acesso à bancada"; Anchor: (Width: 342, Height: 42); }
      }

      Group #RulesScroll {
        FlexWeight: 1;
        LayoutMode: TopScrolling;
        ScrollbarStyle: $Common.@DefaultScrollbarStyle;
        KeepScrollPosition: true;
        Padding: (Right: 10);

        Label #RulesLabel { Style: (...$Common.@DefaultLabelStyle, RenderBold: true); Anchor: (Height: 24, Bottom: 8); Text: "Regras"; }

        Group #NoRulesPanel { Anchor: (Height: 82, Bottom: 8); LayoutMode: Center; Background: #162a3d(0.68); OutlineColor: #45617d(0.58); OutlineSize: 1; Visible: false;
          Label #NoRulesLabel { Style: (...$Common.@DefaultLabelStyle, FontSize: 13, Wrap: true, HorizontalAlignment: Center, VerticalAlignment: Center, TextColor: #9eb2c7); Anchor: (Width: 780, Height: 56); Text: "Nenhuma regra encontrada."; }
        }

        Group #RuleRow0 {
          Anchor: (Height: 108, Bottom: 8);
          LayoutMode: Left;
          Padding: (Top: 8, Bottom: 8, Left: 12, Right: 12);
          Background: #1d3044(0.78);
          OutlineColor: #45617d(0.85);
          OutlineSize: 1;

          Group #RuleIconPanel0 {
            Anchor: (Width: 66, Height: 66, Top: 13, Right: 12);
            LayoutMode: Center;
            Background: #142437(0.92);
            OutlineColor: #55728f(0.72);
            OutlineSize: 1;
            ItemIcon #RuleIcon0 { Anchor: (Width: 54, Height: 52); ItemId: "Ingredient_Stick"; ShowItemTooltip: false; HitTestVisible: false; Visible: false; }
            Label #RuleKindIcon0 { Style: (...$Common.@DefaultLabelStyle, FontSize: 10, Wrap: true, HorizontalAlignment: Center, VerticalAlignment: Center, TextColor: #e9d27e); Anchor: (Width: 60, Height: 48); Text: "RULE"; }
          }

          Group #RuleText0 {
            FlexWeight: 1;
            Anchor: (Height: 88, Right: 12);
            LayoutMode: Top;
            Label #RuleName0 { Style: (...$Common.@DefaultLabelStyle, RenderBold: true); Anchor: (Height: 24); Text: "Rule"; }
            Label #RuleDescription0 { Style: (...$Common.@DefaultLabelStyle, Wrap: true, FontSize: 11, TextColor: #a8bbcf); Anchor: (Height: 62); Text: "Rule details"; }
          }

          Group #RuleActions0 {
            Anchor: (Width: 290, Height: 44, Top: 24);
            LayoutMode: Left;
            $Common.@SecondaryTextButton #EditButton0 { @Text = "Edit"; Anchor: (Width: 112, Height: 42, Right: 10); }
            $Common.@CancelTextButton #DeleteButton0 { @Text = "Delete"; Anchor: (Width: 168, Height: 42); }
          }

          Group #DeleteConfirmation0 {
            Anchor: (Width: 650, Height: 54, Top: 18);
            LayoutMode: Left;
            Visible: false;
            Label #DeleteConfirmationLabel0 { Style: (...$Common.@DefaultLabelStyle, Wrap: true, VerticalAlignment: Center, TextColor: #e9b65f); FlexWeight: 1; Anchor: (Height: 50, Right: 10); Text: "Delete?"; }
            $Common.@SecondaryTextButton #CancelDeleteButton0 { @Text = "Cancel"; Anchor: (Width: 120, Height: 42, Right: 10); }
            $Common.@CancelTextButton #ConfirmDeleteButton0 { @Text = "Confirm"; Anchor: (Width: 160, Height: 42); }
          }
        }
