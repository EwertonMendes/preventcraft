          Background: #1d3044(0.76);
          OutlineColor: #45617d(0.78);
          OutlineSize: 1;
          Group #ResultIconPanel5 {
            Anchor: (Width: 58, Height: 58, Top: 5, Right: 12);
            LayoutMode: Center;
            Background: #142437(0.92);
            OutlineColor: #55728f(0.72);
            OutlineSize: 1;
            ItemIcon #ResultIcon5 { Anchor: (Width: 48, Height: 46); ItemId: "Ingredient_Stick"; ShowItemTooltip: false; HitTestVisible: false; Visible: false; }
            Label #ResultKindIcon5 { Style: (...$Common.@DefaultLabelStyle, FontSize: 10, HorizontalAlignment: Center, VerticalAlignment: Center, TextColor: #e9d27e); Anchor: (Width: 52, Height: 42); Text: "ITEM"; }
          }
          Group #ResultText5 { FlexWeight: 1; Anchor: (Height: 64, Right: 12); LayoutMode: Top;
            Label #ResultName5 { Style: (...$Common.@DefaultLabelStyle, RenderBold: true); Anchor: (Height: 28); Text: "Name"; }
            Label #ResultId5 { Style: (...$Common.@DefaultLabelStyle, FontSize: 11, TextColor: #8fa5bb); Anchor: (Height: 28); Text: "id"; }
          }
          $Common.@TextButton #SelectButton5 { @Text = "Selecionar"; Anchor: (Width: 150, Height: 42, Top: 13); }
        }
        Label #NoResultsLabel {
          Style: (...$Common.@DefaultLabelStyle, HorizontalAlignment: Center, VerticalAlignment: Center, TextColor: #e9b65f);
          Anchor: (Height: 42, Bottom: 8);
          Text: "";
          Visible: false;
        }
      }

      Group #Footer {
        Anchor: (Height: 82, Top: 8);
        LayoutMode: Top;

        Label #StatusLabel {
          Style: (...$Common.@DefaultLabelStyle, Wrap: true, TextColor: #96d4ff);
          Anchor: (Height: 30, Bottom: 6);
          Text: "";
        }

        Group #PagerRow {
          Anchor: (Height: 48, Top: 6);
          LayoutMode: Left;
          $Common.@SecondaryTextButton #PreviousButton { @Text = "Anterior"; Anchor: (Width: 140, Height: 42, Right: 10); }
          Label #PageLabel { Style: (...$Common.@DefaultLabelStyle, HorizontalAlignment: Center, VerticalAlignment: Center); FlexWeight: 1; Anchor: (Height: 42, Right: 10); Text: ""; }
          $Common.@SecondaryTextButton #NextButton { @Text = "Próxima"; Anchor: (Width: 140, Height: 42, Right: 10); }
          $Common.@SecondaryTextButton #BackButton { @Text = "Voltar"; Anchor: (Width: 140, Height: 42, Right: 10); }
          $Common.@CancelTextButton #CloseButton { @Text = "Fechar"; Anchor: (Width: 140, Height: 42); }
        }
      }
    }
  }
