$Common = "../Common.ui";

$Common.@PageOverlay {
  LayoutMode: CenterMiddle;

  $Common.@DecoratedContainer {
    Anchor: (Width: 1000, Height: 840);

    #Title {
      Label #PickerTitle {
        Style: (...$Common.@DefaultLabelStyle, FontSize: 18, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center);
        Padding: (Horizontal: 19);
        Text: "Escolher alvo";
      }
    }

    #Content {
      LayoutMode: Top;
      Padding: (Top: 14, Bottom: 14, Left: 18, Right: 18);

      Label #Subtitle {
        Style: (...$Common.@DefaultLabelStyle, FontSize: 13, Wrap: true, HorizontalAlignment: Center, TextColor: #96a9be);
        Anchor: (Height: 38, Bottom: 10);
        Text: "Busque qualquer item ou bancada pelo nome ou ID.";
      }

      Group #SearchRow {
        Anchor: (Height: 44, Bottom: 10);
        LayoutMode: Left;
        $Common.@TextField #SearchField { FlexWeight: 1; Anchor: (Height: 38, Right: 8); PlaceholderText: "Nome ou ID"; MaxLength: 80; }
        $Common.@TextButton #SearchButton { @Text = "Buscar"; Anchor: (Width: 120, Height: 40, Right: 8); }
        $Common.@TertiaryTextButton #ClearSearchButton { @Text = "Limpar"; Anchor: (Width: 120, Height: 40); }
      }

      Group #Grid {
        Anchor: (Height: 512, Bottom: 8);
        LayoutMode: Top;
        Padding: (Top: 8, Bottom: 8, Left: 8, Right: 8);
        Background: #142437(0.58);
        OutlineColor: #45617d(0.58);
        OutlineSize: 1;

        Group #IconRow0 {
          Anchor: (Height: 120, Bottom: 4);
          LayoutMode: Left;
          Padding: (Left: 29, Right: 29);
          Group #IconCell0 { Anchor: (Width: 140, Height: 120, Right: 10); Padding: (Top: 7, Bottom: 6, Left: 6, Right: 6); LayoutMode: Top; Background: #1d3044(0.82); OutlineColor: #45617d(0.72); OutlineSize: 1;
            Button #IconButton0 { Anchor: (Height: 64, Bottom: 4); LayoutMode: Center; Background: #142437(0.94); OutlineColor: #55728f(0.72); OutlineSize: 1; ItemIcon #IconSlot0 { Anchor: (Width: 58, Height: 54); ItemId: "Ingredient_Stick"; ShowItemTooltip: false; HitTestVisible: false; } Label #IconKind0 { Style: (...$Common.@DefaultLabelStyle, FontSize: 10, HorizontalAlignment: Center, VerticalAlignment: Center, TextColor: #e9d27e); Anchor: (Width: 112, Height: 54); Text: "ITEM"; Visible: false; } }
            Label #IconName0 { Style: (...$Common.@DefaultLabelStyle, FontSize: 9, Wrap: true, HorizontalAlignment: Center, VerticalAlignment: Center); Anchor: (Height: 24); Text: "Item"; }
            Label #IconId0 { Style: (...$Common.@DefaultLabelStyle, FontSize: 8, HorizontalAlignment: Center, VerticalAlignment: Center, TextColor: #8398ad); Anchor: (Height: 14); Text: "Item_Id"; }
          }
          Group #IconCell1 { Anchor: (Width: 140, Height: 120, Right: 10); Padding: (Top: 7, Bottom: 6, Left: 6, Right: 6); LayoutMode: Top; Background: #1d3044(0.82); OutlineColor: #45617d(0.72); OutlineSize: 1;
