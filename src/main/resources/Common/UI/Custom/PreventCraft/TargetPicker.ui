            Background: #1d3044(0.76);
            OutlineColor: #45617d(0.78);
            OutlineSize: 1;
            Group #ResultIconPanel6 { Anchor: (Width: 58, Height: 58, Top: 5, Right: 12); LayoutMode: Center; Background: #142437(0.92); OutlineColor: #55728f(0.72); OutlineSize: 1;
