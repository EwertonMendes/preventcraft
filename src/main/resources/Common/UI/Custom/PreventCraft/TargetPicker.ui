          }
          Group #ResultText3 { FlexWeight: 1; Anchor: (Height: 64, Right: 12); LayoutMode: Top;
            Label #ResultName3 { Style: (...$Common.@DefaultLabelStyle, RenderBold: true); Anchor: (Height: 28); Text: "Name"; }
            Label #ResultId3 { Style: (...$Common.@DefaultLabelStyle, FontSize: 11, TextColor: #8fa5bb); Anchor: (Height: 28); Text: "id"; }
          }
          $Common.@TextButton #SelectButton3 { @Text = "Selecionar"; Anchor: (Width: 150, Height: 42, Top: 13); }
        }
        Group #ResultRow4 {
          Anchor: (Height: 82, Bottom: 8);
          LayoutMode: Left;
          Padding: (Top: 7, Bottom: 7, Left: 10, Right: 10);
          Background: #1d3044(0.76);
          OutlineColor: #45617d(0.78);
          OutlineSize: 1;
          Group #ResultIconPanel4 {
            Anchor: (Width: 58, Height: 58, Top: 5, Right: 12);
            LayoutMode: Center;
