            Button #IconButton20 { Anchor: (Height: 64, Bottom: 4); LayoutMode: Center; Background: #142437(0.94); OutlineColor: #55728f(0.72); OutlineSize: 1; ItemIcon #IconSlot20 { Anchor: (Width: 58, Height: 54); ItemId: "Ingredient_Stick"; ShowItemTooltip: false; HitTestVisible: false; } Label #IconKind20 { Style: (...$Common.@DefaultLabelStyle, FontSize: 10, HorizontalAlignment: Center, VerticalAlignment: Center, TextColor: #e9d27e); Anchor: (Width: 112, Height: 54); Text: "ITEM"; Visible: false; } }
            Label #IconName20 { Style: (...$Common.@DefaultLabelStyle, FontSize: 9, Wrap: true, HorizontalAlignment: Center, VerticalAlignment: Center); Anchor: (Height: 24); Text: "Item"; }
            Label #IconId20 { Style: (...$Common.@DefaultLabelStyle, FontSize: 8, HorizontalAlignment: Center, VerticalAlignment: Center, TextColor: #8398ad); Anchor: (Height: 14); Text: "Item_Id"; }
          }
          Group #IconCell21 { Anchor: (Width: 140, Height: 120, Right: 10); Padding: (Top: 7, Bottom: 6, Left: 6, Right: 6); LayoutMode: Top; Background: #1d3044(0.82); OutlineColor: #45617d(0.72); OutlineSize: 1;
            Button #IconButton21 { Anchor: (Height: 64, Bottom: 4); LayoutMode: Center; Background: #142437(0.94); OutlineColor: #55728f(0.72); OutlineSize: 1; ItemIcon #IconSlot21 { Anchor: (Width: 58, Height: 54); ItemId: "Ingredient_Stick"; ShowItemTooltip: false; HitTestVisible: false; } Label #IconKind21 { Style: (...$Common.@DefaultLabelStyle, FontSize: 10, HorizontalAlignment: Center, VerticalAlignment: Center, TextColor: #e9d27e); Anchor: (Width: 112, Height: 54); Text: "ITEM"; Visible: false; } }
            Label #IconName21 { Style: (...$Common.@DefaultLabelStyle, FontSize: 9, Wrap: true, HorizontalAlignment: Center, VerticalAlignment: Center); Anchor: (Height: 24); Text: "Item"; }
            Label #IconId21 { Style: (...$Common.@DefaultLabelStyle, FontSize: 8, HorizontalAlignment: Center, VerticalAlignment: Center, TextColor: #8398ad); Anchor: (Height: 14); Text: "Item_Id"; }
          }
          Group #IconCell22 { Anchor: (Width: 140, Height: 120, Right: 10); Padding: (Top: 7, Bottom: 6, Left: 6, Right: 6); LayoutMode: Top; Background: #1d3044(0.82); OutlineColor: #45617d(0.72); OutlineSize: 1;
            Button #IconButton22 { Anchor: (Height: 64, Bottom: 4); LayoutMode: Center; Background: #142437(0.94); OutlineColor: #55728f(0.72); OutlineSize: 1; ItemIcon #IconSlot22 { Anchor: (Width: 58, Height: 54); ItemId: "Ingredient_Stick"; ShowItemTooltip: false; HitTestVisible: false; } Label #IconKind22 { Style: (...$Common.@DefaultLabelStyle, FontSize: 10, HorizontalAlignment: Center, VerticalAlignment: Center, TextColor: #e9d27e); Anchor: (Width: 112, Height: 54); Text: "ITEM"; Visible: false; } }
            Label #IconName22 { Style: (...$Common.@DefaultLabelStyle, FontSize: 9, Wrap: true, HorizontalAlignment: Center, VerticalAlignment: Center); Anchor: (Height: 24); Text: "Item"; }
            Label #IconId22 { Style: (...$Common.@DefaultLabelStyle, FontSize: 8, HorizontalAlignment: Center, VerticalAlignment: Center, TextColor: #8398ad); Anchor: (Height: 14); Text: "Item_Id"; }
          }
          Group #IconCell23 { Anchor: (Width: 140, Height: 120); Padding: (Top: 7, Bottom: 6, Left: 6, Right: 6); LayoutMode: Top; Background: #1d3044(0.82); OutlineColor: #45617d(0.72); OutlineSize: 1;
            Button #IconButton23 { Anchor: (Height: 64, Bottom: 4); LayoutMode: Center; Background: #142437(0.94); OutlineColor: #55728f(0.72); OutlineSize: 1; ItemIcon #IconSlot23 { Anchor: (Width: 58, Height: 54); ItemId: "Ingredient_Stick"; ShowItemTooltip: false; HitTestVisible: false; } Label #IconKind23 { Style: (...$Common.@DefaultLabelStyle, FontSize: 10, HorizontalAlignment: Center, VerticalAlignment: Center, TextColor: #e9d27e); Anchor: (Width: 112, Height: 54); Text: "ITEM"; Visible: false; } }
            Label #IconName23 { Style: (...$Common.@DefaultLabelStyle, FontSize: 9, Wrap: true, HorizontalAlignment: Center, VerticalAlignment: Center); Anchor: (Height: 24); Text: "Item"; }
            Label #IconId23 { Style: (...$Common.@DefaultLabelStyle, FontSize: 8, HorizontalAlignment: Center, VerticalAlignment: Center, TextColor: #8398ad); Anchor: (Height: 14); Text: "Item_Id"; }
          }
        }

        Label #NoResultsLabel {
          Style: (...$Common.@DefaultLabelStyle, Wrap: true, HorizontalAlignment: Center, VerticalAlignment: Center, TextColor: #96a9be);
          FlexWeight: 1;
          Anchor: (Height: 54);
          Text: "Nenhum resultado";
          Visible: false;
        }
      }

      Group #ResultRow {
        Anchor: (Height: 28, Bottom: 6);
        LayoutMode: Left;
        Label #ResultLabel { Style: (...$Common.@DefaultLabelStyle, FontSize: 12, TextColor: #96a9be); FlexWeight: 1; Anchor: (Height: 24); Text: "0 resultados"; }
      }

      Group #PaginationRow {
        Anchor: (Height: 42, Bottom: 8);
        LayoutMode: Left;
        $Common.@SecondaryTextButton #PreviousButton { @Text = "<"; Anchor: (Width: 120, Height: 38); }
        Label #PageLabel { Style: (...$Common.@DefaultLabelStyle, HorizontalAlignment: Center, VerticalAlignment: Center); FlexWeight: 1; Anchor: (Height: 38); Text: "Página 1 / 1"; }
        $Common.@SecondaryTextButton #NextButton { @Text = ">"; Anchor: (Width: 120, Height: 38); }
      }

      Group { FlexWeight: 1; }
      Group #BottomRow {
        Anchor: (Height: 44);
        LayoutMode: Left;
        $Common.@SecondaryTextButton #BackButton { @Text = "Voltar"; Anchor: (Width: 150, Height: 40); }
        Group { FlexWeight: 1; }
      }
    }

    $Common.@CloseButton #CloseButton { Anchor: (Top: -10, Right: -10, Width: 32, Height: 32); }
  }
}
