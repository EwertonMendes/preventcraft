          OutlineSize: 1;
          Group #ResultIconPanel3 {
            Anchor: (Width: 58, Height: 58, Top: 5, Right: 12);
            LayoutMode: Center;
            Background: #142437(0.92);
            OutlineColor: #55728f(0.72);
