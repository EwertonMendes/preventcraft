            ItemIcon #ResultIcon4 { Anchor: (Width: 48, Height: 46); ItemId: "Ingredient_Stick"; ShowItemTooltip: false; HitTestVisible: false; Visible: false; }
            Label #ResultKindIcon4 { Style: (...$Common.@DefaultLabelStyle, FontSize: 10, HorizontalAlignment: Center, VerticalAlignment: Center, TextColor: #e9d27e); Anchor: (Width: 52, Height: 42); Text: "ITEM"; }
          }
          Group #ResultText4 { FlexWeight: 1; Anchor: (Height: 64, Right: 12); LayoutMode: Top;
            Label #ResultName4 { Style: (...$Common.@DefaultLabelStyle, RenderBold: true); Anchor: (Height: 28); Text: "Name"; }
