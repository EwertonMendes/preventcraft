            Label #ResultId2 { Style: (...$Common.@DefaultLabelStyle, FontSize: 11, TextColor: #8fa5bb); Anchor: (Height: 28); Text: "id"; }
          }
          $Common.@TextButton #SelectButton2 { @Text = "Selecionar"; Anchor: (Width: 150, Height: 42, Top: 13); }
        }
