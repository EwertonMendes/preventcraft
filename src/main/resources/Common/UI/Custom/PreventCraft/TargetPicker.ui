$Common = "../Common.ui";

$Common.@PageOverlay {
  LayoutMode: CenterMiddle;

  $Common.@DecoratedContainer {
    Anchor: (Width: 880, Height: 800);

    #Title {
      Label #PickerTitle { Style: (...$Common.@DefaultLabelStyle, FontSize: 18, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center, TextColor: #F4D06F); Padding: (Horizontal: 19); Text: "Choose target"; }
    }

    #Content {
      LayoutMode: Top;
      Padding: (Top: 16, Bottom: 16, Left: 22, Right: 22);

      Label #SubtitleLabel { Style: (...$Common.@DefaultLabelStyle, Wrap: true, TextColor: #a8bbcf); Anchor: (Height: 44, Bottom: 10); Text: "Search by translated name or id."; }

      Group #SearchRow { Anchor: (Height: 48, Bottom: 10); LayoutMode: Left;
        $Common.@TextField #SearchField { Anchor: (Height: 38, Right: 8); FlexWeight: 1; PlaceholderText: "Name or id"; MaxLength: 256; }
        $Common.@SecondaryTextButton #SearchButton { @Text = "Search"; Anchor: (Width: 120, Height: 42, Right: 8); }
        $Common.@TertiaryTextButton #ClearSearchButton { @Text = "Clear"; Anchor: (Width: 110, Height: 42); }
      }

      Label #ResultsLabel { Style: (...$Common.@DefaultLabelStyle, RenderBold: true); Anchor: (Height: 24, Bottom: 8); Text: "Results"; }

      Group #ResultsScroll { FlexWeight: 1; LayoutMode: TopScrolling; ScrollbarStyle: $Common.@DefaultScrollbarStyle; KeepScrollPosition: true; Padding: (Right: 10);

          Group #ResultRow0 {
            Anchor: (Height: 82, Bottom: 8);
            LayoutMode: Left;
            Padding: (Top: 7, Bottom: 7, Left: 10, Right: 10);
            Background: #1d3044(0.76);
            OutlineColor: #45617d(0.78);
            OutlineSize: 1;
            Group #ResultIconPanel0 { Anchor: (Width: 58, Height: 58, Top: 5, Right: 12); LayoutMode: Center; Background: #142437(0.92); OutlineColor: #55728f(0.72); OutlineSize: 1;
              ItemIcon #ResultIcon0 { Anchor: (Width: 48, Height: 46); ItemId: "Ingredient_Stick"; ShowItemTooltip: false; HitTestVisible: false; Visible: false; }
              Label #ResultKindIcon0 { Style: (...$Common.@DefaultLabelStyle, FontSize: 10, HorizontalAlignment: Center, VerticalAlignment: Center, TextColor: #e9d27e); Anchor: (Width: 52, Height: 42); Text: "ITEM"; }
            }
            Group #ResultText0 { FlexWeight: 1; Anchor: (Height: 64, Right: 12); LayoutMode: Top;
              Label #ResultName0 { Style: (...$Common.@DefaultLabelStyle, RenderBold: true); Anchor: (Height: 28); Text: "Name"; }
              Label #ResultId0 { Style: (...$Common.@DefaultLabelStyle, FontSize: 11, TextColor: #8fa5bb); Anchor: (Height: 28); Text: "id"; }
            }
            $Common.@TextButton #SelectButton0 { @Text = "Select"; Anchor: (Width: 140, Height: 42, Top: 13); }
          }

          Group #ResultRow1 {
            Anchor: (Height: 82, Bottom: 8);
            LayoutMode: Left;
            Padding: (Top: 7, Bottom: 7, Left: 10, Right: 10);
            Background: #1d3044(0.76);
            OutlineColor: #45617d(0.78);
            OutlineSize: 1;
